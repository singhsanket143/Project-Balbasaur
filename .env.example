# ---- Server ----
PORT=3000

# Shared secret that protects the webhook endpoint.
# Learnyst only lets you configure a destination URL, so we append this token
# to the URL as ?token=... and/or send it as the "x-webhook-token" header.
# Generate one with:  openssl rand -hex 24
WEBHOOK_TOKEN=replace-with-a-long-random-string

# Which Learnyst events should trigger a welcome email (comma separated).
# Learnyst event names seen in the wild: purchase, sign_up, enrollment, trial_enrolment.
# Leave as "*" to send for every event that contains a learner email.
WELCOME_EVENTS=*

# ---- Email (SMTP) ----
# Works with any SMTP provider (Gmail, Zoho, SendGrid, Mailgun, Amazon SES, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@algocam.com
SMTP_PASS=your-app-password

# "From" address shown to students
MAIL_FROM_NAME=Algocam
MAIL_FROM_EMAIL=hello@algocam.com

# Optional: send a copy of every welcome email here (e.g. your support inbox)
MAIL_BCC=

# ---- Branding (used in the email template) ----
COMPANY_NAME=Algocam
SUPPORT_EMAIL=support@algocam.com
LMS_LOGIN_URL=https://your-school.learnyst.com

# Set to "true" to log emails to the console instead of actually sending them.
DRY_RUN=false

# ---- Reliability / retries ----
# Accepted webhooks are saved to a durable on-disk queue (data/queue.json) and
# emailed by a background worker, so restarts/crashes never lose an enrollment
# and transient SMTP failures are retried automatically.
QUEUE_POLL_MS=5000
# Total attempts before a job is moved to the dead-letter state.
RETRY_MAX_ATTEMPTS=8

# ---- CCAvenue (second, redundant enrollment source) ----
# CCAvenue Dynamic Event Notifications POST an AES-encrypted payload that we
# decrypt with your Working Key (Settings -> API Keys in the CCAvenue dashboard).
CCAVENUE_WORKING_KEY=

# Cross-source reconciliation (so a student is welcomed exactly once):
# - If an email was welcomed within this window, the backup source won't re-send.
RECONCILE_WINDOW_MS=43200000
# - Grace delay on the CCAvenue path so Learnyst (richer payload) usually wins.
CCAVENUE_DELAY_MS=120000
